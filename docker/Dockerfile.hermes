FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    curl git nodejs npm \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt

RUN git clone https://github.com/NousResearch/hermes-agent.git

WORKDIR /opt/hermes-agent

RUN python -m venv venv && \
    . venv/bin/activate && \
    pip install --no-cache-dir -e ".[all]" && \
    pip install --no-cache-dir python-docx lxml

COPY agent/microsoft_oauth.py /opt/hermes-agent/agent/microsoft_oauth.py
COPY tools/microsoft_graph_tool.py /opt/hermes-agent/tools/microsoft_graph_tool.py
COPY tools/rss_news_tool.py /opt/hermes-agent/tools/rss_news_tool.py

# Expose the registered Microsoft 365 dispatcher in Hermes default/API/cron toolsets.
# Hermes clones upstream at build time, so patch toolsets.py inside the built image.
RUN python - <<'PY2'
from pathlib import Path

path = Path("/opt/hermes-agent/toolsets.py")
text = path.read_text()

if '"microsoft365"' not in text.split("_HERMES_CORE_TOOLS = [", 1)[1].split("]", 1)[0]:
    text = text.replace(
        '    # Cross-platform messaging (gated on gateway running via check_fn)\n    "send_message",',
        '    # Cross-platform messaging (gated on gateway running via check_fn)\n    "send_message",\n    # Microsoft 365 / Microsoft Graph dispatcher\n    "microsoft365",'
    )

# Also make the API-server-specific toolset explicit in case it bypasses _HERMES_CORE_TOOLS.
if '"microsoft365",' not in text.split('"hermes-api-server":', 1)[1].split('"hermes-cli":', 1)[0]:
    text = text.replace(
        '            # Cronjob management\n            "cronjob",',
        '            # Cronjob management\n            "cronjob",\n            # Microsoft 365 / Microsoft Graph dispatcher\n            "microsoft365",'
    )

path.write_text(text)
print("Patched /opt/hermes-agent/toolsets.py with microsoft365")
PY2

# Make microsoft365 visible to Hermes platform tool selection.
# The API server uses hermes_cli.tools_config._get_platform_tools(...),
# which derives enabled tools from CONFIGURABLE_TOOLSETS, not only toolsets.py.
RUN python - <<'PY3'
from pathlib import Path

path = Path("/opt/hermes-agent/hermes_cli/tools_config.py")
text = path.read_text()

if '("microsoft365",' not in text:
    text = text.replace(
        '    ("messaging",       "📨 Cross-Platform Messaging",  "send_message"),',
        '    ("messaging",       "📨 Cross-Platform Messaging",  "send_message"),\n'
        '    ("microsoft365",    "🏢 Microsoft 365",             "Outlook, Calendar, OneDrive, Word, To Do"),'
    )

path.write_text(text)
print("Patched /opt/hermes-agent/hermes_cli/tools_config.py with microsoft365")
PY3


# Direct passthrough for preformatted Microsoft 365 email subject lines.
# This avoids asking the model to rewrite/copy the clean tool result, which
# caused malformed output in OpenWebUI/API responses.
RUN python - <<'PY4'
from pathlib import Path

path = Path("/opt/hermes-agent/run_agent.py")
text = path.read_text()

needle = """                    self._execute_tool_calls(assistant_message, messages, effective_task_id, api_call_count)

                    # Reset per-turn retry counters after successful tool
"""

insert = """                    self._execute_tool_calls(assistant_message, messages, effective_task_id, api_call_count)

                    # Direct-return clean preformatted Microsoft 365 subject lines.
                    # The tool result is already the user-facing answer; avoid a second
                    # model call that may corrupt copied text.
                    try:
                        _tc_names_for_passthrough = {tc.function.name for tc in assistant_message.tool_calls}
                        if _tc_names_for_passthrough == {"microsoft365"}:
                            _m365_args = {}
                            for _tc in assistant_message.tool_calls:
                                if _tc.function.name == "microsoft365":
                                    try:
                                        _m365_args = json.loads(_tc.function.arguments or "{}")
                                    except Exception:
                                        _m365_args = {}
                                    break

                            if _m365_args.get("action") == "list_recent_email_subject_lines":
                                _last_tool_msg = None
                                for _m in reversed(messages):
                                    if isinstance(_m, dict) and _m.get("role") == "tool":
                                        _last_tool_msg = _m
                                        break

                                if _last_tool_msg:
                                    _tool_content = _last_tool_msg.get("content") or ""
                                    _direct_response = ""
                                    try:
                                        _parsed_tool = json.loads(_tool_content)
                                        _direct_response = str(_parsed_tool.get("result") or "")
                                    except Exception:
                                        _direct_response = str(_tool_content)

                                    final_response = _direct_response.strip()
                                    _turn_exit_reason = "direct_microsoft365_subject_lines_passthrough"
                                    if final_response:
                                        messages.append({"role": "assistant", "content": final_response})
                                        if self.stream_delta_callback:
                                            try:
                                                self.stream_delta_callback(final_response)
                                            except Exception:
                                                pass
                                    self._session_messages = messages
                                    self._save_session_log(messages)
                                    break
                    except Exception as _passthrough_error:
                        logger.debug("Microsoft365 subject-line passthrough failed: %s", _passthrough_error, exc_info=True)

                    # Reset per-turn retry counters after successful tool
"""

if "direct_microsoft365_subject_lines_passthrough" in text:
    print("run_agent.py passthrough already patched")
else:
    if needle not in text:
        raise SystemExit("Could not find run_agent.py tool execution block")
    text = text.replace(needle, insert, 1)
    path.write_text(text)
    print("Patched /opt/hermes-agent/run_agent.py for Microsoft 365 direct passthrough")
PY4

COPY skills/productivity/microsoft-365 /opt/microsoft-365-skill

WORKDIR /app

COPY scripts/start-hermes.sh /app/start-hermes.sh

EXPOSE 8642 3000

CMD ["/app/start-hermes.sh"]
